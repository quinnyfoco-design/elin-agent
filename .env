## Get your Groq key at https://console.groq.com
GROQ_API_KEY="your_actual_token_here"

# Get your GitHub token at https://github.com/settings/tokens (fine-grained, models:read scope)
GITHUB_TOKEN="your_actual_token_here"

# GitHub Models model (options: openai/gpt-4.1, deepseek/deepseek-v4-flash, etc.)
GITHUB_MODEL="openai/gpt-4.1"

# Put ur telegram bot token here
TELEGRAM_BOT_TOKEN=your_actual_token_here
